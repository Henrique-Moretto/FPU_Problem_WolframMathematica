Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"T", "[", "n_", "]"}], ":=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"1", "/", "2"}], " ", 
      RowBox[{
       RowBox[{"P", "[", 
        RowBox[{"i", ",", "n"}], "]"}], "^", "2"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "M"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"V", "[", "n_", "]"}], ":=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"1", "/", "2"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"X", "[", 
          RowBox[{
           RowBox[{"i", "+", "1"}], ",", "n"}], "]"}], "-", 
         RowBox[{"X", "[", 
          RowBox[{"i", ",", "n"}], "]"}]}], ")"}], "^", "2"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "0", ",", "M"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"energia", "[", "n_", "]"}], ":=", 
   RowBox[{
    RowBox[{"T", "[", "n", "]"}], "+", 
    RowBox[{"V", "[", "n", "]"}]}]}], ";"}], "\n", 
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"energia", "[", "n", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "m"}], "}"}]}], "]"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9616194606404753`*^9, 3.961619460641478*^9}, {
