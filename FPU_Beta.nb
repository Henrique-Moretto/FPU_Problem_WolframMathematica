     RowBox[{"2.", "/", 
      RowBox[{"(", 
       RowBox[{"M", "+", "1"}], ")"}]}], "]"}], "*", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"X", "[", 
        RowBox[{"j", ",", "n"}], "]"}], "*", 
       RowBox[{"Sin", "[", 
